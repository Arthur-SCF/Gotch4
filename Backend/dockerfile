# Build stage
FROM oven/bun:latest AS builder
WORKDIR /app

# Vite build-time env vars (override Frontend/.env for production)
ARG VITE_KEYCLOAK_URL
ARG VITE_APP_URL
ARG VITE_KEYCLOAK_REALM=gotch4
ARG VITE_KEYCLOAK_CLIENT_ID=gotch4-spa
ARG VITE_API_URL
ENV VITE_KEYCLOAK_URL=$VITE_KEYCLOAK_URL
ENV VITE_APP_URL=$VITE_APP_URL
ENV VITE_KEYCLOAK_REALM=$VITE_KEYCLOAK_REALM
ENV VITE_KEYCLOAK_CLIENT_ID=$VITE_KEYCLOAK_CLIENT_ID
ENV VITE_API_URL=$VITE_API_URL

# Copy all source files
COPY . ./

# Install frontend and backend dependencies
RUN cd Frontend && bun install
RUN cd Backend && bun install

# Generate Prisma (dummy DATABASE_URL required by prisma.config.ts at generate time)
RUN cd Backend && DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy bunx prisma generate

# Build frontend
RUN cd Frontend && bun run build

# Build backend
RUN cd Backend && bun run build

# Runtime stage
FROM oven/bun:latest
WORKDIR /app

COPY Backend/package*.json ./
RUN bun install

COPY --from=builder /app/Backend/dist ./dist
COPY --from=builder /app/Backend/public ./public
COPY --from=builder /app/Backend/src/templates ./src/templates
COPY --from=builder /app/Backend/prisma ./prisma
COPY --from=builder /app/Backend/prisma.config.ts ./prisma.config.ts
RUN DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy bunx prisma generate

RUN groupadd --system app \
    && useradd --system --no-create-home --gid app app \
    && mkdir -p /app/uploads \
    && chown -R app:app /app
USER app

EXPOSE 3000
CMD ["sh", "-c", "bunx prisma migrate deploy && bunx prisma db seed && bun run dist/server.js"]
