# ================================================================
# Gotch4 Backend — Local Development Configuration
# ================================================================
# For Docker/production use the root .env.example instead.
# Copy this file to .env and adjust for your local setup.
#
#   cp .env.example .env
# ================================================================

# --- Database ---
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/capture

# --- MinIO Object Storage ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=exploits
MINIO_USE_SSL=false

# --- Backend Server ---
PORT=3000

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Local dev:   http://localhost:5173
# Production:  https://gotch4.yourdomain.com
CORS_ORIGINS=http://localhost:5173

# --- Webhook ---
# Base URL of this backend — used to build the webhook URL shown in settings.
WEBHOOK_URL=http://localhost:3000/webhook

# --- Keycloak ---
# Internal URL (container-to-container in Docker, or local KC in dev).
# Local dev:  http://localhost:8080
# Docker:     http://keycloak:8080
KEYCLOAK_URL=http://localhost:8080

# Realm name configured in Keycloak.
KEYCLOAK_REALM=gotch4

# Public-facing Keycloak URL — must match the `iss` claim in JWTs.
# Usually the same as KEYCLOAK_URL in dev; may differ behind a reverse proxy.
# Local dev:   http://localhost:8080
# Production:  https://keycloak.yourdomain.com
KEYCLOAK_ISSUER_URL=http://localhost:8080
