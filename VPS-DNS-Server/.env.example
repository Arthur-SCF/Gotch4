# VPS DNS Server Configuration
# Copy this file to .env and fill in your values

# Base domain for DNS queries (must match main app settings)
DNS_DOMAIN=collab.example.com

# Webhook callback URL (your main app's public URL via Cloudflare Tunnel)
WEBHOOK_URL=https://your-tunnel.trycloudflare.com/api/dns/callback

# Authentication token (must match main app settings, 32+ characters)
AUTH_TOKEN=your-secure-32-character-or-longer-token-here

# Public IP address of this VPS (to return in A records)
DNS_RESPONSE_IP=203.0.113.42

# TTL for DNS responses (0 = no caching, recommended for testing)
DNS_TTL=0

# DNS server port (default: 53)
DNS_PORT=53

# ── HTTP Subdomain Forwarding (optional) ──────────────────────────────────────
# When set, the VPS also listens on HTTP_PORT and proxies all requests to APP_URL,
# preserving the original Host header so the app's subdomain detection fires.
# This lets HTTP hits to *.DNS_DOMAIN (not just DNS lookups) appear as events.
#
# APP_URL: public URL of your main app (Cloudflare Tunnel or direct HTTPS).
# Leave unset to disable HTTP forwarding entirely.
APP_URL=https://your-tunnel.trycloudflare.com

# Port to listen on for incoming HTTP requests (default: 80).
# Requires root or cap_net_bind_service for ports < 1024.
HTTP_PORT=80
